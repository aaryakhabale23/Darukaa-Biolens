{
  "expo": {
    "name": "BioLens",
    "slug": "biolens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "biolens",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2D6A4F"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D6A4F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": ["CAMERA", "ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"],
      "package": "com.darukaa.biolens"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-fast-tflite",
        {
          "enableCoreMLDelegate": false
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "BioLens needs camera access to photograph plants for species identification."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BioLens needs your location to tag plant observations with GPS coordinates."
        }
      ],
      "expo-sharing"
    ]
  }
}
