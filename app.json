{
  "expo": {
    "name": "BioLens",
    "slug": "biolens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "biolens",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#2D6A4F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.darukaa.biolens",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBirWbECqDd0FwUM92G3aIBg8dbr_QKBWg"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-fast-tflite",
      [
        "expo-camera",
        {
          "cameraPermission": "BioLens needs camera access to photograph plants for species identification."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "BioLens needs your location to tag plant observations with GPS coordinates."
        }
      ],
      "expo-sharing"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d7e09267-f15e-4cba-9544-51c622c5b861"
      }
    }
  }
}
